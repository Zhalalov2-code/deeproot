# ── Kontaktformular / SMTP ─────────────────────────────────────────────
# Kopieren Sie diese Datei zu ".env.local" und tragen Sie Ihre echten Werte ein.
# WICHTIG: Tragen Sie echte Passwörter NUR in .env.local ein, niemals hier.
# .env.local wird NICHT ins Git-Repository übernommen.

# SMTP-Server Ihres E-Mail-Anbieters (z. B. der Anbieter von deeproot.one)
SMTP_HOST=smtp.office365.com

# Port: 587 (STARTTLS, üblich) oder 465 (SSL)
SMTP_PORT=587

# "true" nur bei Port 465 (implizites SSL). Bei 587 leer lassen oder "false".
SMTP_SECURE=false

# Zugangsdaten des Postfachs, über das gesendet wird
SMTP_USER=info@deeproot.one
SMTP_PASS=hier-das-postfach-passwort

# Empfänger der Kontaktanfragen (Standard: SMTP_USER, wenn leer)
CONTACT_TO=info@deeproot.one

# Absenderadresse (muss beim Anbieter erlaubt sein; Standard: SMTP_USER)
CONTACT_FROM=info@deeproot.one
